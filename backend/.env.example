# Local dev (Docker Postgres on port 5433)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/aura_gold

# Or use your installed PostgreSQL on port 5432:
# DATABASE_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@localhost:5432/aura_gold

JWT_SECRET_KEY=dev-secret-change-in-production

# Live gold price (MetalPriceAPI)
GOLD_PRICE_API_KEY=your_metalpriceapi_key
GOLD_PRICE_API_URL=https://api.metalpriceapi.com/v1/latest
GOLD_PRICE_SYNC_SECONDS=300
